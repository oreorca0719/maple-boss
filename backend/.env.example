# Nexon Open API
NEXON_API_KEY=your_nexon_api_key_here

# AWS (로컬 개발 시에만 사용, ECS에서는 Task Role이 자동 주입)
AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=your_access_key_id      # 로컬 전용
# AWS_SECRET_ACCESS_KEY=your_secret_key     # 로컬 전용

# DynamoDB
DYNAMODB_TABLE_NAME=maple-boss-scheduler
DYNAMODB_ENDPOINT_URL=                      # 빈 값 = 실제 AWS 사용 (DynamoDB Local 시: http://localhost:8000)

# Application
APP_ENV=development                         # development | production
APP_SECRET_KEY=change-this-to-a-random-secret-key
APP_CORS_ORIGINS=http://localhost:3000
